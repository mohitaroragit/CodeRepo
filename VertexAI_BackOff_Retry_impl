vertexai.init(project=Project_Id,location=REGION)
config=GenerationConfig(temperature=0.5,max_output_tokens=512)
def get_images_url_from_bucket(bucket_name,delimiter=None):
    storage_client = storage.Client(project=Project_Id)
    blobs=storage_client.list_blobs(bucket_name,delimiter=delimiter)
    images=[
        f"gs://{bucket_name}/{blob.name}"
        for blob in blobs
        if blob.name.endswith(tuple([".jpg",".png",".jpeg"]))

    ]
    return images
async def async_ask_gemini(contents,model_name=DEFAULT_MODEL_NAME):
    multimodal_model=GenerativeModel(model_name)
    response=await multimodal_model.generate_content_async(
        contents=contents,
        generation_config=config
    )
    return response.text
@retry(wait=wait_random_exponential(multiplier=1,  max=60))
async def retry_async_ask_gemini(contents,model_name=DEFAULT_MODEL_NAME):
    multimodal_model=GenerativeModel(model_name)
    response=await multimodal_model.generate_content_async(
        contents=contents,generation_config=config
    )

    return response.text
